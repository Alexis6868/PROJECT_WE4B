<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Welcome!{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
        
        <style>
            body { margin: 0; display: flex; flex-direction: column; min-height: 100vh; font-family: sans-serif; }
            header { background: #1a1a1a; color: white; padding: 10px 5%; }
            .navbar { display: flex; justify-content: space-between; align-items: center; }
            .nav-links { display: flex; gap: 20px; list-style: none; }
            .nav-links a { color: white; text-decoration: none; }
            .main-content { flex: 1; padding: 20px; }
            footer { background: #1a1a1a; color: white; padding: 20px 5%; margin-top: auto; }
            .btn-admin { background: #c0392b; padding: 5px 10px; border-radius: 4px; }
        </style>

        {% block stylesheets %}{% endblock %}
        {% block javascripts %}{% block importmap %}{{ importmap('app') }}{% endblock %}{% endblock %}
    </head>
    <body>
        {% set current_route = app.request.attributes.get('_route') %}

        <header>
            <nav class="navbar">
                <div class="logo">
                    <a href="{{ path('app_main') }}" style="font-size: 1.6rem; color: white; font-weight: 800; text-decoration: none;">
                        TANK<span style="color: #29e622;">RENT</span>
                    </a>
                </div>
                <ul class="nav-links">
                    <li><a href="{{ path('app_main') }}" class="{{ current_route == 'app_main' ? 'active' : '' }}">Accueil</a></li>
                    <li><a href="{{ path('app_catalogue') }}" class="{{ current_route == 'app_catalogue' ? 'active' : '' }}">Catalogue</a></li>
                    {% if app.user %}
                        <li><a href="{{ path('app_reservation_index') }}" class="{{ current_route starts with 'app_reservation' ? 'active' : '' }}">Mes Réservations</a></li>
                        {% if is_granted('ROLE_ADMIN') %}
                            <li><a href="{{ path('app_vehicule_index') }}" class="btn-admin {{ current_route starts with 'app_vehicule' ? 'active' : '' }}">Vehicules</a></li>
                            <li><a href="{{ path('app_reservation_index') }}" class="btn-admin {{ current_route starts with 'app_reservation' ? 'active' : '' }}">Réservations</a></li>
                            <li><a href="{{ path('app_entrepot_index') }}" class="btn-admin {{ current_route starts with 'app_entrepot' ? 'active' : '' }}">Entrepôts</a></li>                            
                        {% endif %}
                        <li><a href="{{ path('app_logout') }}" style="color: #95a5a6;">Déconnexion</a></li>
                    {% else %}
                        <li><a href="{{ path('app_login') }}" class="{{ current_route == 'app_login' ? 'active' : '' }}">Connexion</a></li>
                        <li><a href="{{ path('app_register') }}" class="{{ current_route == 'app_register' ? 'active' : '' }}" style="color: #01f70d;">S'inscrire</a></li>
                    {% endif %}
                </ul>
            </nav>
        </header>

        <main class="main-content">
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="flash-message flash-{{ label }}">
                        {{ message }}
                    </div>
                {% endfor %}
            {% endfor %}

            {% block body %}{% endblock %}
        </main>

        <footer>
            <div class="footer-grid" style="display: flex; justify-content: space-between; gap: 20px;">
                <div class="footer-section">
                    <h4>TankRent</h4>
                    <p>Leader mondial de la location de blindés.</p>
                </div>
                <div class="footer-section">
                    <h4>Contact</h4>
                    <p>Avenue du Maréchal Foch 95625, France</p>
                </div>
            </div>
            <div class="footer-bottom" style="text-align: center; border-top: 1px solid #333; margin-top: 10px; padding-top: 10px;">
                <p>&copy; {{ "now"|date("Y") }} TankRent - Créé avec soin par Alexis et Yann</p>
            </div>
        </footer>
    </body>
</html>
