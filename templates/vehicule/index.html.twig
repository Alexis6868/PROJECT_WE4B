{% extends 'base.html.twig' %}

{% block title %}Administration véhicules{% endblock %}

{% block body %}
<section class="admin-form-page">
    <div class="admin-form-header">
        <p class="login-kicker">Administration flotte</p>
        <h1>Gestion des véhicules blindés</h1>
        <p>Consultez l’état du parc, vérifiez les données techniques et ajoutez de nouveaux véhicules au catalogue.</p>
    </div>

    <div class="admin-toolbar">
        <a href="{{ path('app_vehicule_new') }}" class="main-cta">Ajouter un véhicule</a>
    </div>

    <div class="admin-table-card">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Véhicule</th>
                    <th>Type</th>
                    <th>État</th>
                    <th>Masse</th>
                    <th>Maintenance</th>
                    <th>Description</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
            {% for vehicule in vehicules %}
                <tr>
                    <td>#{{ vehicule.id }}</td>
                    <td>
                        <div class="admin-vehicle-cell">
                            <img src="{{ vehicule.image }}" alt="{{ vehicule.nom }}">
                            <strong>{{ vehicule.nom }}</strong>
                        </div>
                    </td>
                    <td><span class="tank-type">{{ vehicule.type }}</span></td>
                    <td>{{ vehicule.etat }}</td>
                    <td>{{ vehicule.masse }} t</td>
                    <td>{{ vehicule.indiceMaintenance }}</td>
                    <td class="admin-description">{{ vehicule.description }}</td>
                    <td>
                        <div class="admin-actions">
                            <a href="{{ path('app_vehicule_show', {'id': vehicule.id}) }}">Voir</a>
                            <a href="{{ path('app_vehicule_edit', {'id': vehicule.id}) }}">Modifier</a>
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="8" class="admin-empty">Aucun véhicule enregistré.</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</section>
{% endblock %}
