{{ form_start(form, {'attr': {'class': 'technical-form warehouse-form'}}) }}
    <div class="technical-form-grid warehouse-form-grid">
        <fieldset class="technical-section">
            <legend>Informations de stockage</legend>

            <div class="form-field">
                {{ form_label(form.adresse, 'Adresse de l’entrepôt', {'label_attr': {'title': 'Exemple : Zone industrielle Alpha, 75000 Paris'}}) }}
                {{ form_widget(form.adresse) }}
                {{ form_errors(form.adresse) }}
            </div>

            <div class="form-field">
                {{ form_label(form.capacite, 'Capacité maximale', {'label_attr': {'title': 'Exemple : 12 pour un entrepôt pouvant accueillir 12 véhicules'}}) }}
                {{ form_widget(form.capacite) }}
                {{ form_errors(form.capacite) }}
            </div>
        </fieldset>

        <fieldset class="technical-section warehouse-help">
            <legend>Gestion du parc</legend>
            <p>La capacité permet d’anticiper le nombre de véhicules blindés pouvant être affectés à cet emplacement.</p>
            <p>Utilisez une adresse claire pour faciliter le suivi logistique et les opérations de maintenance.</p>
        </fieldset>
    </div>

    <div class="technical-actions">
        <button class="main-cta technical-submit">{{ button_label|default('Enregistrer') }}</button>
    </div>
{{ form_end(form) }}
