{% extends 'base.html.twig' %}

{% block title %}Modifier l’entrepôt{% endblock %}

{% block body %}
<section class="admin-form-page warehouse-page">
    <div class="admin-form-header">
        <p class="login-kicker">Administration stockage</p>
        <h1>Modifier un entrepôt</h1>
        <p>Mettez à jour l’adresse ou la capacité de stockage de cet emplacement.</p>
    </div>

    {{ include('entrepot/_form.html.twig', {'button_label': 'Mettre à jour'}) }}

    <div class="reservation-admin-links">
        <a href="{{ path('app_entrepot_index') }}" class="admin-back-link">Retour aux entrepôts</a>
        {{ include('entrepot/_delete_form.html.twig') }}
    </div>
</section>

{% endblock %}
