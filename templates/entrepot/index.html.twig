{% extends 'base.html.twig' %}

{% block title %}Entrepôts{% endblock %}

{% block body %}
<section class="admin-form-page warehouse-page">
    <div class="admin-form-header">
        <p class="login-kicker">Administration stockage</p>
        <h1>Gestion des entrepôts</h1>
        <p>Suivez les emplacements disponibles, leurs capacités et les zones de stockage de la flotte.</p>
    </div>

    <div class="admin-toolbar">
        <a href="{{ path('app_entrepot_new') }}" class="main-cta">Ajouter un entrepôt</a>
    </div>

    <div class="admin-table-card">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Adresse</th>
                    <th>Capacité</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
            {% for entrepot in entrepots %}
                <tr>
                    <td>#{{ entrepot.id }}</td>
                    <td>
                        <strong>{{ entrepot.adresse }}</strong>
                    </td>
                    <td>{{ entrepot.capacite }} véhicules</td>
                    <td>
                        <div class="admin-actions">
                            <a href="{{ path('app_entrepot_show', {'id': entrepot.id}) }}">Voir</a>
                            <a href="{{ path('app_entrepot_edit', {'id': entrepot.id}) }}">Modifier</a>
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="4" class="admin-empty">Aucun entrepôt enregistré.</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</section>
{% endblock %}
