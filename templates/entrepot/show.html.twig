{% extends 'base.html.twig' %}

{% block title %}Détail entrepôt{% endblock %}

{% block body %}
<section class="admin-form-page warehouse-page">
    <div class="admin-form-header">
        <p class="login-kicker">Administration stockage</p>
        <h1>Détail de l’entrepôt</h1>
        <p>Consultez les informations de stockage de cet emplacement.</p>
    </div>

    <div class="warehouse-detail-card technical-form">
        <div class="warehouse-detail-item">
            <span>ID</span>
            <strong>#{{ entrepot.id }}</strong>
        </div>

        <div class="warehouse-detail-item">
            <span>Adresse</span>
            <strong>{{ entrepot.adresse }}</strong>
        </div>

        <div class="warehouse-detail-item">
            <span>Capacité</span>
            <strong>{{ entrepot.capacite }} véhicules</strong>
        </div>
    </div>

    <div class="reservation-admin-links">
        <a href="{{ path('app_entrepot_index') }}" class="admin-back-link">Retour aux entrepôts</a>
        <div class="admin-actions">
            <a href="{{ path('app_entrepot_edit', {'id': entrepot.id}) }}">Modifier</a>
        </div>
        {{ include('entrepot/_delete_form.html.twig') }}
    </div>
</section>
{% endblock %}
