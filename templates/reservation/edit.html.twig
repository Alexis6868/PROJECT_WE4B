{% extends 'base.html.twig' %}

{% block title %}Modifier la réservation{% endblock %}

{% block body %}
<section class="admin-form-page reservation-page">
    <div class="admin-form-header">
        <p class="login-kicker">Réservation</p>
        <h1>Modifier une réservation</h1>
        <p>Ajustez les dates de location. Les informations seront sauvegardées après validation.</p>
    </div>

    {{ include('reservation/_form.html.twig', {'button_label': 'Mettre à jour'}) }}

    <div class="reservation-admin-links">
        <a href="{{ path('app_reservation_index') }}" class="admin-back-link">Retour aux réservations</a>
        {{ include('reservation/_delete_form.html.twig') }}
    </div>
</section>

{% endblock %}
