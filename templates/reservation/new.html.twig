{% extends 'base.html.twig' %}

{% block title %}Nouvelle réservation{% endblock %}

{% block body %}
<section class="admin-form-page reservation-page">
    <div class="admin-form-header">
        <p class="login-kicker">Réservation</p>
        <h1>Planifier une location</h1>
        <p>Sélectionnez vos dates de location. Le prix sera calculé automatiquement lors de la validation.</p>
    </div>

    {% for message in app.flashes('error') %}
        <div class="login-alert">{{ message }}</div>
    {% endfor %}

    {% if reservation.idVehicule %}
        <div class="reservation-selected-card">
            <img src="{{ reservation.idVehicule.image }}" alt="{{ reservation.idVehicule.nom }}">
            <div>
                <span class="tank-type">{{ reservation.idVehicule.type }}</span>
                <h2>{{ reservation.idVehicule.nom }}</h2>
                <p>{{ reservation.idVehicule.description }}</p>
            </div>
        </div>
    {% endif %}

    {{ include('reservation/_form.html.twig') }}

    <a href="{{ path('app_catalogue') }}" class="admin-back-link">Retour au catalogue</a>
</section>
{% endblock %}
