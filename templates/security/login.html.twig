{% extends 'base.html.twig' %}

{% block title %}Connexion{% endblock %}

{% block body %}
<section class="login-page signin-page textured-page-bg">
    <div class="login-panel">
        <div class="login-intro">
            <p class="login-kicker">Espace client</p>
            <h1>Connexion TankRent</h1>
            <p>Accédez à vos réservations, retrouvez votre catalogue et préparez votre prochaine sortie blindée.</p>
        </div>

        <form method="post" class="login-form">
            {% if error %}
                <div class="login-alert">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
            {% endif %}

            {% if app.user %}
                <div class="login-alert">
                    Vous êtes connecté avec {{ app.user.userIdentifier }}, <a href="{{ logout_path() }}">déconnexion</a>
                </div>
            {% endif %}

            <div class="form-field">
                <label for="inputEmail">Adresse email</label>
                <input type="email" value="{{ last_username }}" name="email" id="inputEmail" autocomplete="email" required autofocus>
            </div>

            <div class="form-field">
                <label for="inputPassword">Mot de passe</label>
                <input type="password" name="password" id="inputPassword" autocomplete="current-password" required>
            </div>

            <input type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('authenticate') }}">

            <label class="remember-choice">
                <input type="checkbox" name="_remember_me">
                <span>Se souvenir de moi</span>
            </label>

            <button class="main-cta login-submit" type="submit">
                Se connecter
            </button>
        </form>
    </div>
</section>
{% endblock %}
