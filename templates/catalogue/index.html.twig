{% extends 'base.html.twig' %}

{% block title %}Catalogue{% endblock %}


{% block body %}
<section class="catalogue-page">
    <div class="catalogue-header">
        <h1>Notre flotte de véhicules blindés</h1>
        <p>Comparez les modèles disponibles, vérifiez leur état et choisissez le blindé le plus adapté à votre événement.</p>
    </div>

    <div class="catalogue-filters">
        <input type="text" id="searchInput" placeholder="Rechercher un modèle ou un type...">

        <select id="statusFilter">
            <option value="all">Tous les états</option>
            <option value="Opérationnel">Opérationnel</option>
            <option value="En maintenance">En maintenance</option>
            <option value="En panne">En panne</option>
        </select>
    </div>

    <div class="tank-grid" id="tankGrid">
    {% for vehicule in vehicules %}
        <div class="card bg-base-100 w-96 shadow-sm tank-card" data-search="{{ vehicule.nom|lower }} {{ vehicule.type|lower }}" data-etat="{{ vehicule.etat }}">
            <figure>
                <img src="{{ vehicule.image }}" alt="{{ vehicule.nom }}">
            </figure>

            <div class="card-body">
                <div class="card-heading">
                    <h2 class="card-title">{{ vehicule.nom }}</h2>
                    <span class="tank-type">{{ vehicule.type }}</span>
                </div>

                <p>{{ vehicule.description }}</p>

                <div class="tank-meta">
                    <span>État : <strong>{{ vehicule.etat }}</strong></span>
                    <span>Masse : <strong>{{ vehicule.masse }} tonnes</strong></span>
                </div>

                <div class="card-actions justify-end">
                    <a href="{{ path('app_reservation_new', {'id_vehicule': vehicule.id}) }}" class="main-cta btn-louer">Louer</a>
                </div>
            </div>
        </div>
    {% endfor %}
    </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const searchInput = document.getElementById('searchInput');
    const statusFilter = document.getElementById('statusFilter');
    const cards = document.querySelectorAll('.tank-card');

    function filterTanks() {
        const searchTerm = searchInput.value.toLowerCase().trim();
        const selectedStatus = statusFilter.value.toLowerCase();

        cards.forEach(card => {
            const tankName = card.getAttribute('data-search').toLowerCase();
            const tankStatus = card.getAttribute('data-etat').toLowerCase();
            const tankNom = card.getAttribute('data-nom').toLowerCase();

            const matchesSearch = tankName.includes(searchTerm);
            const matchesStatus = (selectedStatus === 'all' || tankStatus === selectedStatus);

            if (matchesSearch && matchesStatus) {
                card.style.display = 'block';
            } else {
                card.style.display = 'none';
            }
        });
    }

    searchInput.addEventListener('input', filterTanks);
    statusFilter.addEventListener('change', filterTanks);
});
</script>
{% endblock %}
