{% extends 'base.html.twig' %}

{% block title %}Hello CatalogueController!{% endblock %}


{% block body %}
<style>
    .tank-grid {
        display: flex;
        flex-wrap: wrap;
        gap: 20px;
        padding: 20px;
        justify-content: center;
    }
    .tank-card {
        border: 1px solid #ddd;
        border-radius: 8px;
        width: 300px;
        overflow: hidden;
        box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        transition: transform 0.2s;
    }
    .tank-card:hover { transform: scale(1.02); }
    .tank-img { width: 100%; height: 200px; background: #eee; object-fit: cover; }
    .tank-info { padding: 15px; }
    .btn-louer {
        display: block;
        text-align: center;
        background: #2c3e50;
        color: white;
        padding: 10px;
        text-decoration: none;
        border-radius: 4px;
        margin-top: 10px;
    }
</style>

<h1>Notre Flotte de Tanks</h1>

{# templates/catalogue/index.html.twig #}

<div class="filters" style="margin: 20px; display: flex; gap: 15px; justify-content: center;">
    <input type="text" id="searchInput" placeholder="Rechercher un modèle..." 
           style="padding: 8px; border-radius: 4px; border: 1px solid #ccc; width: 250px;">
    
    <select id="statusFilter" style="padding: 8px; border-radius: 4px; border: 1px solid #ccc;">
        <option value="all">Tous les états</option>
        <option value="Opérationnel">Opérationnel</option>
        <option value="En maintenance">En maintenance</option>
        <option value="En panne">En panne</option>
    </select>
</div>

<div class="tank-grid" id="tankGrid">
    {% for vehicule in vehicules %}
        {# On ajoute des "data-attributes" pour que le JS puisse lire les infos facilement #}
        <div class="tank-card" data-nom="{{ vehicule.nom|lower }}" data-type="{{ vehicule.type|lower }}" data-etat="{{ vehicule.etat }}">
            <div class="tank-info">
                <h2>{{ vehicule.nom }}</h2>
                <h3>{{ vehicule.type }}</h3>
                <img src="{{vehicule.image}}" alt="">
                <p>État : <span class="etat-label">{{ vehicule.etat }}</span></p>
                <p>Masse : {{ vehicule.masse }} tonnes</p>
                <a href="{{ path('app_reservation_new', {'id_vehicule': vehicule.id}) }}" class="btn-louer">Louer</a>
            </div>
        </div>
    {% endfor %}
</div>
<script>
document.addEventListener('DOMContentLoaded', function() {
    const searchInput = document.getElementById('searchInput');
    const statusFilter = document.getElementById('statusFilter');
    const cards = document.querySelectorAll('.tank-card');

    function filterTanks() {
        
        const searchTerm = searchInput.value.toLowerCase().trim();
        const selectedStatus = statusFilter.value.toLowerCase();

        cards.forEach(card => {
            // On récupère les data et on les passe en minuscules d'office
            const tankName = card.getAttribute('data-type').toLowerCase();
            const tankStatus = card.getAttribute('data-etat').toLowerCase();
            const tankNom = card.getAttribute('data-nom').toLowerCase();

            const matchesSearch = tankName.includes(searchTerm);
            const matchesStatus = (selectedStatus === 'all' || tankStatus === selectedStatus);

            if (matchesSearch && matchesStatus) {
                card.style.display = 'block';
            } else {
                card.style.display = 'none';
            }
        });
    }

    searchInput.addEventListener('input', filterTanks);
    statusFilter.addEventListener('change', filterTanks);
});
</script>
{% endblock %}

