{% extends 'base.html.twig' %}

{% block title %}Inscription{% endblock %}

{% block body %}
<section class="login-page register-page textured-page-bg">
    <div class="login-panel register-panel">
        <div class="login-intro">
            <p class="login-kicker">Créer un compte</p>
            <h1>Rejoindre TankRent</h1>
            <p>Créez votre espace client pour réserver un véhicule blindé, suivre vos demandes et préparer vos prochains événements.</p>
        </div>

        <div class="login-form register-form">
            {{ form_errors(registrationForm) }}

            {{ form_start(registrationForm) }}
                <div class="register-fields">
                    <div class="form-field">
                        {{ form_label(registrationForm.nom, 'Nom *') }}
                        {{ form_widget(registrationForm.nom) }}
                        {{ form_errors(registrationForm.nom) }}
                    </div>

                    <div class="form-field">
                        {{ form_label(registrationForm.prenom, 'Prénom *') }}
                        {{ form_widget(registrationForm.prenom) }}
                        {{ form_errors(registrationForm.prenom) }}
                    </div>

                    <div class="form-field">
                        {{ form_label(registrationForm.email, 'Adresse email *') }}
                        {{ form_widget(registrationForm.email) }}
                        {{ form_errors(registrationForm.email) }}
                    </div>

                    <div class="form-field">
                        {{ form_label(registrationForm.tel, 'Téléphone *') }}
                        {{ form_widget(registrationForm.tel) }}
                        {{ form_errors(registrationForm.tel) }}
                    </div>

                    <div class="form-field register-password">
                        {{ form_label(registrationForm.plainPassword, 'Mot de passe *') }}
                        {{ form_widget(registrationForm.plainPassword) }}
                        {{ form_errors(registrationForm.plainPassword) }}
                    </div>

                    
                </div>

                <div> <p> * champ obligatoire </p> </div>

                <div class="remember-choice register-terms">
                    {{ form_widget(registrationForm.agreeTerms) }}
                    {{ form_label(registrationForm.agreeTerms, 'J’accepte les conditions générales') }}
                    {{ form_errors(registrationForm.agreeTerms) }}
                </div>

                <button type="submit" class="main-cta login-submit">
                    Créer mon compte
                </button>
            {{ form_end(registrationForm) }}
        </div>
    </div>
</section>
{% endblock %}
